DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

SECRET_KEY=change-me-generate-a-random-secret
SESSION_SECRET_KEY=change-me-generate-a-random-session-secret

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=apartamentos_valeria

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

DEV_FRONTEND_URL=http://localhost:3000
DEV_BACKEND_URL=http://localhost:8000
PRODUCTION_FRONTEND_URL=https://your-domain.com
PRODUCTION_BACKEND_URL=https://your-domain.com

MINIO_ENDPOINT=s3.example.com
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET_NAME=recibos
MINIO_SECURE=true
MINIO_REGION=us-east-1

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
CORS_CREDENTIALS=true

ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENROUTER_API_KEY=replace-with-openrouter-api-key
